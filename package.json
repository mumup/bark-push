{
  "name": "bark-push",
  "version": "0.1.1",
  "description": "A typed Node.js SDK for the Bark Server API V2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mumup/bark-push.git"
  },
  "homepage": "https://github.com/mumup/bark-push#readme",
  "bugs": {
    "url": "https://github.com/mumup/bark-push/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm test && pnpm build"
  },
  "engines": { "node": ">=18" },
  "keywords": ["bark", "push", "notification", "typescript"],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.12.1"
}
